{
  "name": "appliance.sh",
  "version": "1.27.3",
  "description": "Appliance is a platform to install and run applications on the cloud",
  "homepage": "https://github.com/appliance-sh/appliance.sh#readme",
  "bugs": {
    "url": "https://github.com/appliance-sh/appliance.sh/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/appliance-sh/appliance.sh.git"
  },
  "license": "MIT",
  "author": "Eliot Lim",
  "lint-staged": {
    "**/*": [
      "npx eslint",
      "prettier --write --ignore-unknown"
    ]
  },
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "build": "nx run-many --target=build --all",
    "clean": "rm -rf ./node_modules && pnpm -r run clean",
    "lint:check": "pnpm exec eslint . && prettier . --check",
    "lint:fix": "pnpm exec eslint --fix . && prettier . --fix --write",
    "dev": "nx run-many --target=build --all && concurrently -k -n sdk,infra,server -c blue,magenta,green \"pnpm --filter @appliance.sh/sdk run build:watch\" \"pnpm --filter @appliance.sh/infra run build:watch\" \"pnpm --filter @appliance.sh/api-server run start:dev\"",
    "dev:setup": "pnpm --filter @appliance.sh/sdk run dev:setup && pnpm --filter @appliance.sh/cli run dev:setup && pnpm --filter @appliance.sh/infra run dev:setup",
    "deploy": "pnpm --filter @appliance.sh/infra run deploy",
    "test": "echo \"Error: no test specified\" && exit 1",
    "prepare": "husky || true",
    "release": "nx release",
    "release:ci": "nx release --yes"
  },
  "private": true,
  "nx": {
    "name": "appliance-workspace",
    "includedScripts": []
  },
  "devDependencies": {
    "@appliance.sh/sdk": "workspace:*",
    "@eslint/js": "^9.29.0",
    "@nx/js": "^21.5.2",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.13.5",
    "concurrently": "^9.2.1",
    "eslint": "^9.29.0",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^16.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "nx": "21.5.2",
    "prettier": "3.5.3",
    "ts-node": "^10.9.2",
    "typescript-eslint": "^8.34.0"
  }
}
