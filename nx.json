{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "targetDefaults": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["{projectRoot}/dist"],
      "cache": true
    },
    "test": {
      "cache": true
    },
    "release": {
      "dependsOn": ["^release"]
    },
    "postbuild": {
      "dependsOn": ["^postbuild"]
    }
  },
  "release": {
    "version": {
      "conventionalCommits": true
    },
    "projects": ["@appliance.sh/*", "appliance.sh", "appliance-workspace"],
    "projectsRelationship": "fixed",
    "releaseTagPattern": "v{version}",
    "changelog": {
      "workspaceChangelog": {
        "createRelease": "github"
      }
    },
    "conventionalCommits": {
      "types": {
        "feat": { "semverBump": "minor", "changelog": { "title": "Features" } },
        "fix": { "semverBump": "patch", "changelog": { "title": "Bug Fixes" } },
        "perf": { "semverBump": "patch", "changelog": { "title": "Performance" } },
        "chore": { "semverBump": "patch", "changelog": { "title": "Chores" } },
        "ci": { "semverBump": "patch", "changelog": { "title": "CI" } },
        "docs": { "semverBump": "none", "changelog": { "title": "Documentation" } },
        "refactor": { "semverBump": "patch", "changelog": { "title": "Refactoring" } }
      }
    }
  }
}
