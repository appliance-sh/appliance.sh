{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "targetDefaults": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["{projectRoot}/dist"],
      "cache": true
    },
    "test": {
      "cache": true
    },
    "release": {
      "dependsOn": ["^release"]
    },
    "postbuild": {
      "dependsOn": ["^postbuild"]
    }
  },
  "release": {
    "version": {
      "conventionalCommits": true
    },
    "groups": {
      "packages": {
        "projects": ["sdk", "cli", "install-aws", "api-server", "infra"],
        "projectsRelationship": "fixed"
      }
    },
    "changelog": {
      "workspaceChangelog": {
        "createRelease": "github"
      }
    }
  }
}
