{
  "name": "@appliance.sh/app",
  "version": "1.35.0",
  "private": true,
  "description": "Shared React application for the Appliance console (web) and desktop shells",
  "license": "MIT",
  "author": "Eliot Lim",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/app.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf ./dist",
    "dev:setup": "echo 'pnpm workspaces handle linking automatically'"
  },
  "dependencies": {
    "@appliance.sh/sdk": "workspace:*",
    "@radix-ui/react-slot": "^1.1.1",
    "@tanstack/react-query": "^5.60.0",
    "buffer": "^6.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "react-router": "^7.0.2",
    "tailwind-merge": "^2.5.5"
  },
  "devDependencies": {
    "@appliance.sh/bootstrap": "workspace:*",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.3"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
