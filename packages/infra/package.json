{
  "name": "@appliance.sh/infra",
  "version": "1.32.3",
  "private": true,
  "description": "Deploy the Appliance Infrastructure",
  "repository": {
    "type": "git",
    "url": "https://github.com/appliance-sh/appliance.sh.git",
    "directory": "packages/infra"
  },
  "license": "MIT",
  "author": "Eliot Lim",
  "main": "src/index.ts",
  "types": "dist/lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib/index.d.ts",
      "import": "./dist/lib/index.js",
      "require": "./dist/lib/index.js"
    }
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "tsc",
    "build:watch": "tsc --watch --preserveWatchOutput",
    "clean": "rm -rf ./dist/",
    "deploy:entrypoint": "ts-node src/index.ts",
    "deploy": "pnpm run clean && pulumi up && pnpm run build",
    "dev:setup": "echo 'pnpm workspaces handle linking automatically'"
  },
  "dependencies": {
    "@appliance.sh/sdk": "workspace:*",
    "@pulumi/aws": "^7.16.0",
    "@pulumi/aws-native": "^1.48.0",
    "@pulumi/awsx": "^3.1.0",
    "@pulumi/pulumi": "^3.216.0"
  },
  "devDependencies": {
    "@types/node": "24.12.2",
    "typescript": "^5.7.3"
  }
}
