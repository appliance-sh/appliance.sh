{
  "name": "@appliance.sh/cli",
  "version": "1.45.1",
  "description": "Shell for installing, running, and developing applications on the Appliance platform",
  "repository": {
    "type": "git",
    "url": "https://github.com/appliance-sh/appliance.sh.git",
    "directory": "packages/cli"
  },
  "license": "MIT",
  "author": "Eliot Lim",
  "type": "module",
  "bin": {
    "appliance": "bin/appliance.js"
  },
  "files": [
    "bin",
    "scripts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && pnpm run compile",
    "compile": "bun build src/appliance.ts --compile --outfile=dist/appliance",
    "compile:darwin-arm64": "bun build src/appliance.ts --compile --target=bun-darwin-arm64 --outfile=dist/appliance-aarch64-apple-darwin",
    "compile:darwin-x64": "bun build src/appliance.ts --compile --target=bun-darwin-x64 --outfile=dist/appliance-x86_64-apple-darwin",
    "compile:linux-x64": "bun build src/appliance.ts --compile --target=bun-linux-x64 --outfile=dist/appliance-x86_64-unknown-linux-gnu",
    "compile:linux-arm64": "bun build src/appliance.ts --compile --target=bun-linux-arm64 --outfile=dist/appliance-aarch64-unknown-linux-gnu",
    "compile:windows-x64": "bun build src/appliance.ts --compile --target=bun-windows-x64 --outfile=dist/appliance-x86_64-pc-windows-msvc.exe",
    "compile:all": "pnpm run compile:darwin-arm64 && pnpm run compile:darwin-x64 && pnpm run compile:linux-x64 && pnpm run compile:linux-arm64 && pnpm run compile:windows-x64",
    "postinstall": "node scripts/install-binary.mjs",
    "clean": "rm -rf ./dist/",
    "dev:setup": "pnpm link --global",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@appliance.sh/bootstrap": "workspace:*",
    "@appliance.sh/helper": "workspace:*",
    "@appliance.sh/sdk": "workspace:*",
    "@inquirer/prompts": "^7.10.1",
    "@types/archiver": "^7.0.0",
    "@types/json-diff": "^1.0.3",
    "@types/node": "24.12.2",
    "@vitest/coverage-v8": "^3.2.4",
    "archiver": "^7.0.1",
    "chalk": "^5.4.1",
    "commander": "^14.0.0",
    "json-diff": "^1.0.6",
    "quickjs-emscripten": "^0.32.0",
    "random-word-slugs": "^0.1.7",
    "sucrase": "^3.35.1",
    "typescript": "5.9.3",
    "vitest": "^3.2.4"
  }
}
