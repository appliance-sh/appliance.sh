{
  "name": "@appliance.sh/sdk",
  "version": "1.27.1",
  "description": "SDK for installing, running, and developing applications for the Appliance platform",
  "repository": {
    "type": "git",
    "url": "https://github.com/appliance-sh/appliance.sh.git",
    "directory": "packages/sdk"
  },
  "license": "MIT",
  "author": "Eliot Lim",
  "type": "commonjs",
  "main": "index.js",
  "exports": {
    "require": "./dist/cjs/index.js",
    "import": "./dist/esm/index.js",
    "types": "./dist/types/index.d.ts"
  },
  "types": "./dist/types",
  "scripts": {
    "build": "tsc --module commonjs --outDir dist/cjs && tsc --moduleResolution nodenext --module NodeNext --outDir dist/esm && pnpm run postbuild",
    "build:watch": "tsc --module commonjs --outDir dist/cjs --watch --preserveWatchOutput",
    "clean": "rm -rf ./dist/",
    "dev:setup": "echo 'pnpm workspaces handle linking automatically'",
    "postbuild": "pnpm exec ts-node scripts/postbuild.ts",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "http-message-signatures": "^1.0.4",
    "uuidv7": "^1.1.0",
    "zod": "^4.1.13",
    "zod-to-ts": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0"
  }
}
