{
  "name": "@appliance.sh/sdk",
  "version": "1.33.1",
  "description": "SDK for installing, running, and developing applications for the Appliance platform",
  "repository": {
    "type": "git",
    "url": "https://github.com/appliance-sh/appliance.sh.git",
    "directory": "packages/sdk"
  },
  "license": "MIT",
  "author": "Eliot Lim",
  "type": "commonjs",
  "main": "index.js",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./models": {
      "types": "./dist/types/models/index.d.ts",
      "import": "./dist/esm/models/index.js",
      "require": "./dist/cjs/models/index.js"
    },
    "./client": {
      "types": "./dist/types/client/index.d.ts",
      "import": "./dist/esm/client/index.js",
      "require": "./dist/cjs/client/index.js"
    },
    "./signing": {
      "types": "./dist/types/signing/index.d.ts",
      "import": "./dist/esm/signing/index.js",
      "require": "./dist/cjs/signing/index.js"
    },
    "./storage": {
      "types": "./dist/types/object-store/index.d.ts",
      "import": "./dist/esm/object-store/index.js",
      "require": "./dist/cjs/object-store/index.js"
    }
  },
  "types": "./dist/types",
  "scripts": {
    "build": "tsc --module commonjs --outDir dist/cjs && tsc --module esnext --moduleResolution bundler --outDir dist/esm && pnpm run postbuild",
    "build:watch": "tsc --module commonjs --outDir dist/cjs --watch --preserveWatchOutput",
    "clean": "rm -rf ./dist/",
    "dev:setup": "echo 'pnpm workspaces handle linking automatically'",
    "postbuild": "pnpm exec ts-node scripts/postbuild.ts",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "http-message-signatures": "^1.0.4",
    "uuidv7": "^1.1.0",
    "zod": "^4.1.13",
    "zod-to-ts": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "*"
  }
}
