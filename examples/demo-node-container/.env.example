# Example env file for the local-runtime demo.
#
# `appliance deploy demo-node <env>` looks for `.env.<env>` in the
# working directory (e.g. `.env.prod`) and forwards each KEY=VALUE
# pair into the container. The local executor also uses PORT to
# wire the Service's port + NodePort target, so the container's
# bind port must match.
#
# Copy this file before running the demo:
#   cp .env.example .env.prod

PORT=3000
